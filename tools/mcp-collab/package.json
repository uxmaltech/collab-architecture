{
  "name": "mcp-collab-architecture",
  "version": "0.3.3",
  "type": "module",
  "private": true,
  "description": "MCP server for Collab Architecture graph and vector queries",
  "license": "UNLICENSED",
  "scripts": {
    "start": "[ -f ../../.env ] && node --env-file=../../.env server.mjs || node server.mjs",
    "dev": "[ -f ../../.env ] && node --watch --env-file=../../.env server.mjs || node --watch server.mjs",
    "ingest:v2": "node $([ -f ../../.env ] && echo '--env-file=../../.env') scripts/ingest-v2.mjs",
    "ingest:github": "node $([ -f ../../.env ] && echo '--env-file=../../.env') scripts/ingest-github.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@nebula-contrib/nebula-nodejs": "^3.0.3",
    "express": "^5.1.0",
    "php-parser": "^3.4.0",
    "typescript": "^5.9.3",
    "zod": "^3.25.0"
  }
}
