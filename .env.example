# ── Qdrant ──────────────────────────────────────────
QDRANT_CONTAINER=collab-qdrant
QDRANT_IMAGE=qdrant/qdrant:v1.8.1
QDRANT_URL=http://localhost:6333
# API key for Qdrant — required when Qdrant is exposed over the network (leave empty for local)
QDRANT_API_KEY=

QDRANT_COLLECTION=collab-architecture-canon
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE=Cosine
QDRANT_BATCH_SIZE=64
ARCH_COLLECTION=collab-architecture-canon
BUSINESS_COLLECTION=business-architecture-canon

# V2 scopes — comma-separated. Each scope maps to collection technical-{scope}
# Override per-scope with QDRANT_COLLECTION_TECHNICAL_{SCOPE_UPPER}
MCP_TECHNICAL_SCOPES=uxmaltech
QDRANT_COLLECTION_TECHNICAL_UXMALTECH=technical-uxmaltech
QDRANT_COLLECTION_BUSINESS=business-rules

# ── NebulaGraph ─────────────────────────────────────
NEBULA_VERSION=v3.6.0
NEBULA_COMPOSE=infra/nebula-compose.yaml
NEBULA_CONSOLE_IMAGE=vesoft/nebula-console:v3.6.0
NEBULA_GRAPH_CONTAINER=nebula-graphd
NEBULA_ADDR=graphd
NEBULA_STORAGE_HOST=storaged0
NEBULA_STORAGE_PORT=9779
NEBULA_PORT=9669
NEBULA_USER=root
NEBULA_PASSWORD=nebula
NEBULA_SPACE=collab_architecture
ARCH_SPACE=collab_architecture
BUSINESS_SPACE=business_architecture

# ── Infrastructure ──────────────────────────────────
# Set to true when Qdrant and NebulaGraph run externally (skip docker db-up)
EXTERNAL_SERVICES=false

# ── MCP Server ──────────────────────────────────────
MCP_ENV=local
MCP_HOST=127.0.0.1
MCP_PORT=7337
# Format: clientId1:key1,clientId2:key2 (empty + MCP_ENV=local = no auth)
MCP_API_KEYS=

# ── GitHub Ingestion (ingest:github) ───────────────
# Token with read access to repositories to ingest.
GITHUB_TOKEN=
# Optional: USD price per 1M tokens for estimated embedding cost reporting.
EMBED_PRICE_PER_1M_TOKENS=
# Qdrant collection that stores incremental ingestion cursors.
QDRANT_COLLECTION_INGEST_CURSORS=ingest-cursors
